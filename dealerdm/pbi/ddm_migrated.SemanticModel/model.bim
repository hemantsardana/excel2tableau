          {
            "name": "KPI_2",
            "expression": "VAR SelectedKPI = SELECTEDVALUE('KPI List (copy)'[Value]) RETURN SWITCH(SelectedKPI, \"MQ\", SUM('Extract'[MailQTY]), \"DO\", SUM('Extract'[DealerOrders]), \"DA\", SUM('Extract'[DealerActivations]), \"OR\", DIVIDE(SUM('Extract'[DealerOrders]), SUM('Extract'[MailQTY])), \"AR\", DIVIDE(SUM('Extract'[DealerActivations]), SUM('Extract'[DealerOrders])), \"CPDO\", 0.45 * DIVIDE(SUM('Extract'[MailQTY]), SUM('Extract'[DealerOrders])))",

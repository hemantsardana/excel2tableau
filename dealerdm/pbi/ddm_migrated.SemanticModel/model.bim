          {
            "name": "Yoy_Mon",
            "expression": "VAR MaxDateInTable = CALCULATE(MAX('Extract'[EST_IHD]), ALL('Extract')) VAR CurrentDateInContext = MAX('Extract'[EST_IHD]) RETURN IF( NOT ISBLANK(CurrentDateInContext), SWITCH( TRUE(), MONTH(CurrentDateInContext) = MONTH(MaxDateInTable) && YEAR(CurrentDateInContext) = YEAR(MaxDateInTable), \"Current Month\", MONTH(CurrentDateInContext) = MONTH(MaxDateInTable) && YEAR(CurrentDateInContext) = YEAR(MaxDateInTable) - 1, \"Previous Yr\" ) )",
            "lineageTag": "76fb0c88-d6f5-4dd5-8883-9cd678e9b211"
          },
          {
            "name": "KPI_3",
            "expression": "VAR SelectedKPI = SELECTEDVALUE('KPI List 2 (copy)'[Value]) RETURN SWITCH(SelectedKPI, \"CPDO\", 0.45 * DIVIDE(SUM('Extract'[MailQTY]), SUM('Extract'[DealerOrders])), \"CPDA\", 0.45 * DIVIDE(SUM('Extract'[MailQTY]), SUM('Extract'[DealerActivations])), \"HCPDO\", [Hughes Cost per Dealer Order], \"DCPDO\", [Dealer Cost per Dealer Order], \"SAC\", (0.45 * DIVIDE(SUM('Extract'[MailQTY]), SUM('Extract'[DealerOrders]))) + 391)",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "c0fcd846-1834-4dc8-bc8e-11f223d4f699"
          },
          {
            "name": "Monthly / Weekly View/BDN",
            "expression": [
              "",
              "VAR SelectedView =",
              "    SELECTEDVALUE ( 'Cost Per Call Parameter'[Value] )",
              "",
              "VAR TheDate =",
              "    MAX ( 'Extract_1'[Est_IHD] )",
              "",
              "VAR TheYear =",
              "    FORMAT ( TheDate, \"YY\" )",
              "",
              "VAR TheQuarter =",
              "    \"Q\" & FORMAT ( TheDate, \"Q\" )",
              "",
              "VAR TheWeek =",
              "    \"Wk \" & FORMAT ( TheDate, \"WW\" )",
              "",
              "VAR TheMonth =",
              "    FORMAT ( TheDate, \"MMM\" )",
              "",
              "RETURN",
              "SWITCH (",
              "    SelectedView,",
              "    \"QQ\", TheQuarter & \"'\" & TheYear,",
              "    \"WW\", TheWeek & \"'\" & TheYear,",
              "    \"MM\", TheMonth & \"'\" & TheYear,",
              "    BLANK()",
              ")"
            ],
            "lineageTag": "074b73d8-f5f6-4116-aa0b-f5b6f4908ebc"
          },
          {
            "name": "Mail QTY % of Total",
            "expression": [
              "",
              "DIVIDE(",
              "    SUM('Extract'[MailQTY]),",
              "    CALCULATE(",
              "        SUM('Extract'[MailQTY]),",
              "        REMOVEFILTERS ( 'Extract'[Mail Type Aliased] )",
              "        )",
              "    )",
              "",
              ""
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "72647d80-7642-4a3d-9617-f5285a31beba"
          },
          {
            "name": "Date Range Ext1",
            "expression": [
              "",
              "VAR StartMonth =",
              "     SELECTEDVALUE ( 'Start Date (copy 2)'[Value] ) ",
              "",
              "VAR StartDate =",
              "    DATE ( YEAR ( StartMonth ), MONTH ( StartMonth ), 1 )",
              "",
              "VAR EndDate =",
              "    DATEVALUE ( SELECTEDVALUE ( 'Start Date_1 (copy)'[Value] ) )",
              "",
              "VAR CurrentDate =",
              "    MAX ( 'Extract_1'[Est_IHD] )",
              "",
              "RETURN",
              "IF (",
              "    NOT ISBLANK ( StartDate )",
              "        && NOT ISBLANK ( EndDate )",
              "        && CurrentDate >= StartDate",
              "        && CurrentDate <= EndDate,",
              "    1,",
              "    0",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "3455fd83-69c4-4069-9f12-bf42b76ad4b6"
          },
          {
            "name": "minest",
            "expression": "MIN(Extract_1[Est_IHD])",
            "formatString": "General Date",
            "lineageTag": "ab26776d-02b8-495c-b991-8a18dfc38318"
          },
          {
            "name": "maxest",
            "expression": "MAX(Extract_1[Est_IHD])",
            "formatString": "General Date",
            "lineageTag": "08b9ad73-e18f-481e-a4b0-501727491b84"
          },
          {
            "name": "Count Trend Indicator",
            "expression": [
              "",
              "VAR CurrentValue =",
              "    COALESCE ( [Count (copy)], 0 )",
              "",
              "VAR PreviousValue =",
              "    COALESCE (",
              "        CALCULATE (",
              "            [Count (copy)],",
              "            OFFSET (",
              "                -1,",
              "                ORDERBY ( 'Extract_1'[Est_IHD] ),",
              "                PARTITIONBY ()",
              "            )",
              "        ),",
              "        0",
              "    )",
              "",
              "VAR ChangeRatio =",
              "    DIVIDE (",
              "        CurrentValue - PreviousValue,",
              "        ABS ( PreviousValue )",
              "    )",
              "",
              "RETURN",
              "SWITCH (",
              "    TRUE(),",
              "    ChangeRatio < 0, -1,",
              "    ChangeRatio = 0,  0,",
              "    1",
              ")",
              ""
            ],
            "formatString": "0",
            "lineageTag": "f3704673-569d-445b-bc84-7e8663c8ad57"
          },
          {
            "name": "Date Range Ext",
            "expression": [
              "",
              "VAR StartMonth =",
              "     SELECTEDVALUE ( 'Start Date (copy 2)'[Value] ) ",
              "",
              "VAR StartDate =",
              "    DATE ( YEAR ( StartMonth ), MONTH ( StartMonth ), 1 )",
              "",
              "VAR EndDate =",
              "    DATEVALUE ( SELECTEDVALUE ( 'Start Date_1 (copy)'[Value] ) )",
              "",
              "VAR CurrentDate =",
              "    MAX ( 'Extract'[EST_IHD] )",
              "",
              "RETURN",
              "IF (",
              "    NOT ISBLANK ( StartDate )",
              "        && NOT ISBLANK ( EndDate )",
              "        && CurrentDate >= StartDate",
              "        && CurrentDate <= EndDate,",
              "    1,",
              "    0",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "852de33a-da8f-41a6-9619-e5fcea787145"
          },
          {
            "name": "Mail Count Aug-19",
            "expression": [
              "",
              "CALCULATE(",
              "    [Count (copy)],",
              "    FILTER(",
              "        ALL('Extract_1'),",
              "        Extract_1[Est_IHD] IN {",
              "            DATE(2019, 8, 5),",
              "            DATE(2019, 8, 12)",
              "        }",
              "    )",
              ")",
              ""
            ],
            "formatString": "0.0",
            "lineageTag": "a043a15d-94b3-46fd-8e8e-bfec88961ccd"
          },
          {
            "name": "Mail Count Previous Month",
            "expression": [
              "",
              "VAR CurrentContextDate =",
              "    MAX ( Extract_1[Est_IHD] )",
              "",
              "VAR PrevMonthStart =",
              "    EOMONTH ( CurrentContextDate, -2 ) + 1",
              "",
              "VAR PrevMonthEnd =",
              "    EOMONTH ( CurrentContextDate, -1 )",
              "",
              "RETURN",
              "CALCULATE (",
              "    [Count (copy)],",
              "    FILTER (",
              "        ALL ( Extract_1[Est_IHD] ),",
              "        Extract_1[Est_IHD] >= PrevMonthStart",
              "            && Extract_1[Est_IHD] <= PrevMonthEnd",
              "    )",
              ")",
              "",
              "",
              ""
            ],
            "formatString": "0.0",
            "lineageTag": "27db66f2-a687-4481-b584-6c3024a7a5f6"
          },
          {
            "name": "Mail Count % Change",
            "expression": [
              "",
              "DIVIDE(",
              "    [Mail Count Aug-19] - [Mail Count Previous Month],",
              "    [Mail Count Previous Month])",
              ""
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "ab6a2bda-a828-42a3-afba-6ed09079df95"
          },
          {
            "name": "Mail Count Trend Icon",
            "expression": [
              "",
              "VAR Val = [Mail Count % Change]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(Val), BLANK(),",
              "    Val > 0, UNICHAR(9650),   -- ▲ Up filled triangle",
              "    Val < 0, UNICHAR(9660),   -- ▼ Down filled triangle",
              "    UNICHAR(8212)               -- — Neutral",
              ")",
              ""
            ],
            "lineageTag": "98444cc5-d01e-4778-a9b5-0ec0ae00c8e9"
          },
          {
            "name": "Call Count % Change",
            "expression": [
              "",
              "VAR CallCount =",
              "    CALCULATE (",
              "        SUM ( Extract_1[Total_Calls] ),",
              "        KEEPFILTERS (",
              "            Extract_1[Est_IHD] IN {",
              "                DATE ( 2019, 8, 5 ),",
              "                DATE ( 2019, 8, 12 )",
              "            }",
              "        )",
              "    )",
              "",
              "VAR CurrentContextDate =",
              "    MAX ( Extract_1[Est_IHD] )",
              "",
              "VAR PrevMonthStart =",
              "    EOMONTH ( CurrentContextDate, -2 ) + 1",
              "",
              "VAR PrevMonthEnd =",
              "    EOMONTH ( CurrentContextDate, -1 )",
              "",
              "VAR Prevcount =",
              "    CALCULATE (",
              "        SUM ( Extract_1[Total_Calls] ),",
              "        FILTER (",
              "            ALL ( Extract_1 ),",
              "            Extract_1[Est_IHD] >= PrevMonthStart",
              "                && Extract_1[Est_IHD] <= PrevMonthEnd",
              "        )",
              "    )",
              "",
              "RETURN",
              "    DIVIDE (",
              "        CallCount - Prevcount,",
              "        Prevcount",
              "    )"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "f89a4176-f5ad-4760-b572-9105cff425e7"
          },
          {
            "name": "Call Count % Change YoY",
            "expression": [
              "",
              "VAR CallCount =",
              "    CALCULATE (",
              "        SUM ( Extract_1[Total_Calls] ),",
              "        KEEPFILTERS (",
              "            Extract_1[Est_IHD] IN {",
              "                DATE ( 2019, 8, 5 ),",
              "                DATE ( 2019, 8, 12 )",
              "            }",
              "        )",
              "    )",
              "",
              "VAR CurrentContextDate =",
              "    MAX ( Extract_1[Est_IHD] )",
              "",
              "-- Same month last year (full month)",
              "VAR PrevYearMonthStart =",
              "    DATE (",
              "        YEAR ( CurrentContextDate ) - 1,",
              "        MONTH ( CurrentContextDate ),",
              "        1",
              "    )",
              "",
              "VAR PrevYearMonthEnd =",
              "    EOMONTH ( PrevYearMonthStart, 0 )",
              "",
              "VAR PrevYearCount =",
              "    CALCULATE (",
              "        SUM ( Extract_1[Total_Calls] ),",
              "        FILTER (",
              "            ALL ( Extract_1 ),",
              "            Extract_1[Est_IHD] >= PrevYearMonthStart",
              "                && Extract_1[Est_IHD] <= PrevYearMonthEnd",
              "        )",
              "    )",
              "",
              "RETURN",
              "    IF (",
              "        NOT ISBLANK ( PrevYearCount ),",
              "        DIVIDE ( CallCount - PrevYearCount, PrevYearCount )",
              "    )"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "68d1f2bb-55ce-4292-a2db-f75fc5c1c414"
          },
          {
            "name": "Count % Change YoY",
            "expression": [
              "",
              "VAR CurrentCount =",
              "    CALCULATE (",
              "        [Count (copy)],",
              "        KEEPFILTERS (",
              "            Extract_1[Est_IHD] IN {",
              "                DATE ( 2019, 8, 5 ),",
              "                DATE ( 2019, 8, 12 )",
              "            }",
              "        )",
              "    )",
              "",
              "VAR CurrentContextDate =",
              "    MAX ( Extract_1[Est_IHD] )",
              "",
              "-- Same month last year (full month boundaries)",
              "VAR PrevYearMonthStart =",
              "    DATE (",
              "        YEAR ( CurrentContextDate ) - 1,",
              "        MONTH ( CurrentContextDate ),",
              "        1",
              "    )",
              "",
              "VAR PrevYearMonthEnd =",
              "    EOMONTH ( PrevYearMonthStart, 0 )",
              "",
              "VAR PrevYearCount =",
              "    CALCULATE (",
              "        [Count (copy)],",
              "        FILTER (",
              "            ALL ( Extract_1 ),",
              "            Extract_1[Est_IHD] >= PrevYearMonthStart",
              "                && Extract_1[Est_IHD] <= PrevYearMonthEnd",
              "        )",
              "    )",
              "",
              "RETURN",
              "    IF (",
              "        NOT ISBLANK ( PrevYearCount ),",
              "        DIVIDE ( CurrentCount - PrevYearCount, PrevYearCount )",
              "    )"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "e4e4bbfb-eb5f-4223-a974-b6c7ac5c5a5c"

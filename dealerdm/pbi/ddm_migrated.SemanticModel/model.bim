        ],
        "lineageTag": "f2e13123-4219-4c98-b1df-b6b002dde174",
        "measures": [
          {
            "name": "Home",
            "expression": "\"Home\"",
            "lineageTag": "16bce52c-359f-4f6b-80a0-0f729e9668e8"
          },
          {
            "name": "TWG",
            "expression": "\"TWG Dashboard\"",
            "lineageTag": "5fb07fef-cc43-4304-9e3c-5adf389fdbbc"
          },
          {
            "name": "Matchback Navigation 1",
            "expression": "\"Matchback Dashboard 1\"",
            "lineageTag": "eafc4e1b-3904-46dd-9211-6ec284ee21cd"
          },
          {
            "name": "Matchback Navigation 2",
            "expression": "\"Matchback Dashboard 2\"",
            "lineageTag": "7287a1c2-53f0-4c3f-acd4-b8eb4f0d81aa"
          },
          {
            "name": "DA_LKP",
            "expression": "\"Not convertible: Tableau's LOOKUP function is context-dependent and has no direct DAX equivalent.\"",
            "lineageTag": "6fd0a70d-e280-4291-abc5-d55b0e14b325"
          },
          {
            "name": "Cost per Call",
            "expression": "DIVIDE(SUM('Extract_1'[Retailer_Cost]), SUM('Extract_1'[Total_Calls]))",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "6e682fbb-1efb-4ef8-b16d-9d5505d1f5b3"
          },
          {
            "name": "Resp. Rate",
            "expression": "DIVIDE(SUM('Extract_1'[Total_Calls]), SUM('Extract_1'[Count]))",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "92a8b244-bd71-4a28-8a29-1e5a3c6ec58d"
          },
          {
            "name": "Activation Rate",
            "expression": "DIVIDE(SUM('Extract'[DealerActivations]), SUM('Extract'[DealerOrders]))",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "21a8ac2c-1f7d-45a1-8393-28b73f9277bd"
          },
          {
            "name": "Cost per Dealer Activation",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ],
            "expression": "0.45 * DIVIDE(SUM('Extract'[MailQTY]), SUM('Extract'[DealerActivations]))",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "1358c1bd-7f93-4934-b603-b04e671d0bec"

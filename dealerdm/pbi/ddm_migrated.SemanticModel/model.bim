            "expression": [
              "",
              "VAR SelectedView = SELECTEDVALUE('Cost Per Call Parameter'[Value]) ",
              "VAR TheDate = 'Extract_1'[Est_IHD] ",
              "VAR TheYear = YEAR(TheDate) ",
              "VAR TheQuarter = QUARTER(TheDate) ",
              "VAR TheWeek = WEEKNUM(TheDate, 2) ",
              "VAR TheMonth = FORMAT(TheDate, \"mmm\") ",
              "RETURN ",
              "SWITCH(SelectedView, \"QQ\", \"Q\" & TheQuarter & \"'\" & RIGHT(TheYear, 2), \"WW\", \"Wk \" & TheWeek & \"'\" & RIGHT(TheYear, 2), \"MM\", TheMonth & \"'\" & RIGHT(TheYear, 2))",

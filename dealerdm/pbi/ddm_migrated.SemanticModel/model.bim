          },
          {
            "name": "OR_LKP",
            "expression": "VAR _currentValue = COALESCE('_Measures'[Order Rate], 0) VAR _nextValue = CALCULATE('_Measures'[Order Rate], PARALLELPERIOD('Extract'[EST_IHD], 1, MONTH)) RETURN IF(ISBLANK(_nextValue), BLANK(), SIGN(_currentValue - _nextValue))",
            "formatString": "0",
            "lineageTag": "a710a638-5d2c-4ed8-8de8-27c330198ccc"
          },
          {
            "name": "Dealer Cost",
            "expression": "SUMX('Extract', IF('Extract'[Mail Type Aliased] = \"Radius\", 0, 'Extract'[MailQTY] * 0.45 * 0.2))",
            "lineageTag": "df8fa641-1f6f-4e12-af92-ef0924597079"
          },
          {
            "name": "Hughes Cost",
            "expression": "SUMX('Extract', IF('Extract'[Mail Type Aliased] = \"Radius\", 'Extract'[MailQTY] * 0.45, 'Extract'[MailQTY] * 0.45 * 0.8))",
            "lineageTag": "1b0262ca-c23d-49fb-a534-eafe4ca906d8"

                "    (\"Monthly\", NAMEOF('Extract'[Mon_yr]), 0, \"MM\"),",
                "    (\"Weekly\", NAMEOF('Extract'[Week_yr]), 1, \"WW\"),",
                "    (\"Quarterly\", NAMEOF('Extract'[Qtr_yr]), 2, \"QQ\"),",
                "    (\"Yearly\", NAMEOF('Extract'[Year]), 3, \"YY\")",
                "}"
              ],
              "type": "calculated"
            }
          }
        ]
      }
    ]
  }
}
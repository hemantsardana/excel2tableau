          {
            "name": "Resp. Rate % Change",
            "expression": [
              "",
              "VAR CallCount =",
              "    CALCULATE (",
              "        _Measures[Resp. Rate],",
              "        KEEPFILTERS (",
              "            Extract_1[Est_IHD] IN {",
              "                DATE ( 2019, 8, 5 ),",
              "                DATE ( 2019, 8, 12 )",
              "            }",
              "        )",
              "    )",
              "",
              "VAR CurrentContextDate =",
              "    MAX ( Extract_1[Est_IHD] )",
              "",
              "VAR PrevMonthStart =",
              "    EOMONTH ( CurrentContextDate, -2 ) + 1",
              "",
              "VAR PrevMonthEnd =",
              "    EOMONTH ( CurrentContextDate, -1 )",
              "",
              "VAR Prevcount =",
              "    CALCULATE (",
              "        _Measures[Resp. Rate],",
              "        FILTER (",
              "            ALL ( Extract_1 ),",
              "            Extract_1[Est_IHD] >= PrevMonthStart",
              "                && Extract_1[Est_IHD] <= PrevMonthEnd",
              "        )",
              "    )",
              "",
              "RETURN",
              "    DIVIDE (",
              "        CallCount - Prevcount,",
              "        Prevcount",
              "    )"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "f097fe72-807f-47a6-b61c-925fbefff829"

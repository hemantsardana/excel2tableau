                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "VAR SelectedKPI = SELECTEDVALUE('Monthly / Weekly View  (copy)'[Value]) RETURN SWITCH(SelectedKPI, \"CNT\", SUM('Extract_1'[Count]), \"TC\", SUM('Extract_1'[Total_Calls]), \"RR\", DIVIDE(SUM('Extract_1'[Total_Calls]), SUM('Extract_1'[Count])), \"CPC\", DIVIDE(SUM('Extract_1'[Retailer_Cost]), SUM('Extract_1'[Total_Calls])))",
            "lineageTag": "6c5f879e-d277-45c0-84a7-44b87ac11e76"

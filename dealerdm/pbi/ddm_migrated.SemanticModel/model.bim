          {
            "name": "Mail Count Shape Color",
            "expression": [
              "",
              "VAR v = [Mail Count % Change]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(v), \"#9E9E9E\",   -- Grey",
              "    v > 0, \"#2E7D32\",        -- Green",
              "    v < 0, \"#C62828\",        -- Red",
              "    \"#9E9E9E\"",
              ")",
              ""
            ],
            "lineageTag": "8ba8412f-bc23-4667-a81e-35bb2d6215f4"
          },
          {
            "name": "Count Trend Icon",
            "expression": [
              "",
              "VAR Val = [Count % Change YoY]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(Val), BLANK(),",
              "    Val > 0, UNICHAR(9650),   -- ▲ Up filled triangle",
              "    Val < 0, UNICHAR(9660),   -- ▼ Down filled triangle",
              "    UNICHAR(8212)               -- — Neutral",
              ")"
            ],
            "lineageTag": "c9c635a3-dcb3-4b8a-9b6f-37ddcfba0d6a"
          },

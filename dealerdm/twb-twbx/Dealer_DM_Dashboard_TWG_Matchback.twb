        </style-rule>
      </style>
      <size sizing-mode='automatic' />
      <datasources>
        <datasource caption='Matchback Data' name='federated.1oam6ps0ouz5g21g569k905nta2o' />
        <datasource caption='TWG Job Details 2017+ (Multiple Connections)' name='federated.1thqvk50957jk81cxe9td0j0267o' />
      </datasources>
      <datasource-dependencies datasource='federated.1oam6ps0ouz5g21g569k905nta2o'>
        <column caption='Mail Type Aliased' datatype='string' name='[Calculation_366198961371631627]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='CASE [SRC]&#13;&#10;WHEN &quot;Branded&quot; THEN &quot;Branded-Saturation&quot;&#13;&#10;WHEN &quot;Branded Radius&quot; THEN &quot;Radius&quot;&#13;&#10;WHEN &quot;DealerRadius&quot; THEN &quot;Radius&quot;&#13;&#10;WHEN &quot;Generic&quot; THEN &quot;Generic-Saturation&quot;&#13;&#10;END' />
        </column>
        <column-instance column='[Calculation_366198961371631627]' derivation='None' name='[none:Calculation_366198961371631627:nk]' pivot='key' type='nominal' />
      </datasource-dependencies>
      <datasource-dependencies datasource='federated.1thqvk50957jk81cxe9td0j0267o'>
        <column caption='Mail Type Aliased' datatype='string' name='[Mail Type (copy)]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='CASE [Ad_Group1]&#13;&#10;WHEN &quot;BULK&quot; THEN &quot;Branded-Saturation&quot;&#13;&#10;WHEN &quot;GENERIC&quot; THEN &quot;Generic-Saturation&quot;&#13;&#10;WHEN &quot;EDDM&quot; THEN &quot;EDDM&quot;&#13;&#10;WHEN &quot;RADIUS&quot; THEN &quot;Radius&quot;&#13;&#10;END' />
          <aliases>
            <alias key='&quot;BULK&quot;' value='Branded-Saturation' />
            <alias key='&quot;GENERIC&quot;' value='Generic-Saturation' />
            <alias key='&quot;RADIUS&quot;' value='Radius' />
          </aliases>
        </column>

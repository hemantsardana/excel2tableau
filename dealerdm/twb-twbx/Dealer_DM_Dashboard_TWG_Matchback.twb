            </column>
            <column aggregation='Attribute' caption='Yoy_Mon' datatype='string' name='[Calculation_365636011110227976]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF MONTH([EST_IHD])= MONTH({ EXCLUDE YEAR([EST_IHD]),MONTH([EST_IHD]), [EST_IHD],[Calculation_365636011108364294] :MAX([EST_IHD])} )&#13;&#10;and YEAR([EST_IHD])= YEAR({ EXCLUDE YEAR([EST_IHD]),MONTH([EST_IHD]), [EST_IHD],[Calculation_365636011108364294] :MAX([EST_IHD])} )&#13;&#10;then&#13;&#10;&quot;Current Month&quot;&#13;&#10;ELSEIF &#13;&#10;MONTH([EST_IHD])= MONTH({ EXCLUDE YEAR([EST_IHD]),MONTH([EST_IHD]), [EST_IHD],[Calculation_365636011108364294] :MAX([EST_IHD])} )&#13;&#10;and YEAR([EST_IHD])= YEAR({ EXCLUDE YEAR([EST_IHD]),MONTH([EST_IHD]), [EST_IHD],[Calculation_365636011108364294] :MAX([EST_IHD])} )-1 then&#13;&#10;&quot;Previous Yr&quot;&#13;&#10;END' />
            </column>
            <column caption='Index' datatype='integer' name='[Calculation_365636011131351052]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='INDEX()'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Mail Type Aliased' datatype='string' name='[Calculation_366198961371631627]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [SRC]&#13;&#10;WHEN &quot;Branded&quot; THEN &quot;Branded-Saturation&quot;&#13;&#10;WHEN &quot;Branded Radius&quot; THEN &quot;Radius&quot;&#13;&#10;WHEN &quot;DealerRadius&quot; THEN &quot;Radius&quot;&#13;&#10;WHEN &quot;Generic&quot; THEN &quot;Generic-Saturation&quot;&#13;&#10;END' />
            </column>
            <column caption='Date Range' datatype='boolean' name='[Calculation_369295186755690496]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[EST_IHD] &gt;=  [Parameters].[Start Date (copy 2)] AND [EST_IHD] &lt;= [Parameters].[Start Date_1 (copy)]' />

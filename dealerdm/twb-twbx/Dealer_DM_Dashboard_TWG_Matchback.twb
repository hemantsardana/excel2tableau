            <column caption='Mon_yr' datatype='string' name='[Calculation_365636011108364294]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT(DATENAME(&quot;month&quot;,[EST_IHD]),3)+ &quot; - &quot; + RIGHT(STR([Calculation_354939952070057987]),2)' />
            </column>
            <column caption='CAlc_0' datatype='integer' name='[Calculation_365636011126050825]' role='measure' type='quantitative'>

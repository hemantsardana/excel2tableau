          </filter>
          <filter class='categorical' column='[federated.1oam6ps0ouz5g21g569k905nta2o].[none:Calculation_354939952070057987:ok]' filter-group='14'>
            <groupfilter function='level-members' level='[none:Calculation_354939952070057987:ok]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <sort class='manual' column='[federated.1oam6ps0ouz5g21g569k905nta2o].[none:Calculation_354939952070057987:ok]' direction='ASC'>

            </column>
            <column caption='TC_LKP' datatype='integer' name='[Calculation_712413180622938119]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF &#13;&#10;((ZN(SUM([Total_Calls])) - LOOKUP(ZN(SUM([Total_Calls])), 1)) / ABS(LOOKUP(ZN(SUM([Total_Calls])), 1))) &lt;0 then -1 &#13;&#10;ELSEIF ((ZN(SUM([Total_Calls])) - LOOKUP(ZN(SUM([Total_Calls])), 1)) / ABS(LOOKUP(ZN(SUM([Total_Calls])), 1)))= 0 then 0 &#13;&#10;ELSE 1 END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>

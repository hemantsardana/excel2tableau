        <calculation class='tableau' formula='YEAR([EST_IHD])' />
      </column>
      <column caption='Activation Rate' datatype='real' name='[Calculation_354939952076820484]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([DealerActivations])/SUM([DealerOrders])' />
      </column>
      <column caption='Cost per Dealer Activation' datatype='real' name='[Calculation_354939952077275141]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.45*(sum([MailQTY])/SUM([DealerActivations]))' />
      </column>
      <column caption='Cost per Dealer Order' datatype='real' name='[Calculation_354939952077467654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.45*sum([MailQTY])/SUM([DealerOrders])' />
      </column>
      <column caption='Dealer Cost' datatype='real' name='[Calculation_354939952077586439]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [Mail Categ] = &quot;Radius&quot; then&#13;&#10;0&#13;&#10;else [MailQTY]*0.45*0.2&#13;&#10;end' />
      </column>
      <column caption='Dealer Cost per Dealer Order' datatype='real' name='[Calculation_354939952077717512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Calculation_354939952077586439])/sum([DealerOrders])' />
      </column>
      <column caption='Hughes Cost' datatype='real' name='[Calculation_354939952077893641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [Mail Categ] = &quot;Radius&quot; then&#13;&#10;[MailQTY]*0.45&#13;&#10;else [MailQTY]*0.45*0.8&#13;&#10;END' />
      </column>
      <column caption='Hughes Cost per Dealer Order' datatype='real' name='[Calculation_354939952078045194]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Calculation_354939952077893641])/SUM([DealerOrders])' />
      </column>
      <column caption='Order Rate' datatype='real' name='[Calculation_354939952078143499]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([DealerOrders])/sum([MailQTY])' />
      </column>
      <column caption='SAC' datatype='real' name='[Calculation_354939952078249996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_354939952077467654]+210+181' />
      </column>
      <column caption='Order' datatype='string' name='[Calculation_365636011040665602]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Order&quot;' />
      </column>
      <column caption='MB' datatype='string' name='[Calculation_365636011043131395]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;MB1 Dashboard&quot;' />
      </column>
      <column caption='Mon_yr' datatype='string' name='[Calculation_365636011108364294]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT(DATENAME(&quot;month&quot;,[EST_IHD]),3)+ &quot; - &quot; + RIGHT(STR([Calculation_354939952070057987]),2)' />
      </column>
      <column aggregation='Attribute' caption='Yoy_Mon' datatype='string' name='[Calculation_365636011110227976]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF MONTH([EST_IHD])= MONTH({ EXCLUDE YEAR([EST_IHD]),MONTH([EST_IHD]), [EST_IHD],[Calculation_365636011108364294] :MAX([EST_IHD])} )&#13;&#10;and YEAR([EST_IHD])= YEAR({ EXCLUDE YEAR([EST_IHD]),MONTH([EST_IHD]), [EST_IHD],[Calculation_365636011108364294] :MAX([EST_IHD])} )&#13;&#10;then&#13;&#10;&quot;Current Month&quot;&#13;&#10;ELSEIF &#13;&#10;MONTH([EST_IHD])= MONTH({ EXCLUDE YEAR([EST_IHD]),MONTH([EST_IHD]), [EST_IHD],[Calculation_365636011108364294] :MAX([EST_IHD])} )&#13;&#10;and YEAR([EST_IHD])= YEAR({ EXCLUDE YEAR([EST_IHD]),MONTH([EST_IHD]), [EST_IHD],[Calculation_365636011108364294] :MAX([EST_IHD])} )-1 then&#13;&#10;&quot;Previous Yr&quot;&#13;&#10;END' />
      </column>
      <column caption='CAlc_0' datatype='integer' name='[Calculation_365636011126050825]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='DO_LKP' datatype='integer' name='[Calculation_365636011127234571]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF &#13;&#10;(ZN(SUM([DealerOrders])) - LOOKUP(ZN(SUM([DealerOrders])), 1)) / ABS(LOOKUP(ZN(SUM([DealerOrders])), 1)) &lt;0 then -1 &#13;&#10;ELSEIF (ZN(SUM([DealerOrders])) - LOOKUP(ZN(SUM([DealerOrders])), 1)) / ABS(LOOKUP(ZN(SUM([DealerOrders])), 1))= 0 then 0 &#13;&#10;ELSE 1 END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Index' datatype='integer' name='[Calculation_365636011131351052]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Mail Type Aliased' datatype='string' name='[Calculation_366198961371631627]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [SRC]&#13;&#10;WHEN &quot;Branded&quot; THEN &quot;Branded-Saturation&quot;&#13;&#10;WHEN &quot;Branded Radius&quot; THEN &quot;Radius&quot;&#13;&#10;WHEN &quot;DealerRadius&quot; THEN &quot;Radius&quot;&#13;&#10;WHEN &quot;Generic&quot; THEN &quot;Generic-Saturation&quot;&#13;&#10;END' />
      </column>
      <column caption='Date Range' datatype='boolean' name='[Calculation_369295186755690496]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[EST_IHD] &gt;=  [Parameters].[Start Date (copy 2)] AND [EST_IHD] &lt;= [Parameters].[Start Date_1 (copy)]' />
      </column>
      <column caption='Month_1' datatype='string' name='[Calculation_458804226265014276]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT(DATENAME(&quot;month&quot;,[EST_IHD] ),3)' />
      </column>
      <column caption='Test_Date' datatype='string' hidden='true' name='[Calculation_620089415473332224]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [EST_IHD] &lt; #2016-01-01# THEN &apos;Pre 2010&apos;&#13;&#10;ELSE &apos;Test Not&apos;&#13;&#10;END' />
      </column>
      <column caption='Zero' datatype='integer' hidden='true' name='[Calculation_659777359958810625]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Mail Qty_Str' datatype='string' hidden='true' name='[Calculation_659777359960813570]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Mail Qty&quot;' />
      </column>
      <column aggregation='Sum' caption='MOY_Merge' datatype='integer' hidden='true' name='[Calculation_733242341999394817]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&quot;year&quot;,[EST_IHD],&quot;Monday&quot;)*100 + DATEPART(&quot;month&quot;,[EST_IHD],&quot;Monday&quot;)' />
      </column>
      <column caption='Beam_Status_At_Time' datatype='string' name='[Calculation_733242341999923202]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='//yyyy - mm - dd&#13;&#10;IF [EST_IHD] &lt; #2018-01-04# THEN [Beam_Status_Pre_P1] //Pre P1&#13;&#10;&#13;&#10;ELSEIF #2018-01-04# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2018-04-05# THEN [Beam_Status_P1] // P1 04Jan18 - 05Apr18&#13;&#10;&#13;&#10;ELSEIF #2018-04-05# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2018-05-31# THEN [Beam_Status_P2] // P2 05Jan18 - 31May18&#13;&#10;&#13;&#10;ELSEIF #2018-05-31# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2018-08-02# THEN [Beam_Status_P3] // P3 31May18 - 02Aug18&#13;&#10;&#13;&#10;ELSEIF #2018-08-02# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2018-09-27# THEN [Beam_Status_P4] // P4 02Aug18 - 27Sep18&#13;&#10;&#13;&#10;ELSEIF #2018-09-27# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2019-01-03# THEN [Beam_Status_P5] // P5 27Sep18 - 03Jan19&#13;&#10;&#13;&#10;ELSEIF #2019-01-03# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2019-01-14# THEN [Beam_Status_P6] // P6 03Jan19 - 14Feb19&#13;&#10;&#13;&#10;ELSEIF #2019-02-14# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2019-03-28# THEN [Beam_Status_P7] // P7 14Feb19 - 28Mar19&#13;&#10;&#13;&#10;ELSEIF #2019-03-28# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2019-06-27# THEN [Beam_Status_P8] // P7 28Mar19 - 27Jun19&#13;&#10;&#13;&#10;ELSEIF #2019-06-27# &lt;= [EST_IHD] THEN [Beam_Status_P9] // P9 27Jun19 - Today&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;//if ORDER_RECEIVED_DATE &lt; &quot;04Jan18&quot;d then period=0;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;04Jan18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;05Apr18&quot;d then period=1;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;05Apr18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;31May18&quot;d then period=2;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;31May18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;02Aug18&quot;d then period=3;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;02Aug18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;27Sep18&quot;d then period=4;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;27Sep18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;03Jan19&quot;d then period=5;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;03Jan19&quot;d and ORDER_RECEIVED_DATE &lt; &quot;14Feb19&quot;d then period=6;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;14Feb19&quot;d then period=7;else;' />
      </column>
      <column caption='BST_FLAG' datatype='string' name='[Calculation_733242342003195907]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Beam_Status_At_Time (copy)]&#13;&#10;WHEN &apos;GROWTH&apos; THEN &apos;GROWTH&apos;&#13;&#10;WHEN &apos;STANDARD&apos; THEN &apos;STANDARD&apos;&#13;&#10;WHEN &apos;MANAGED&apos; THEN &apos;MANAGED&apos;&#13;&#10;WHEN &apos;NO J2&apos; THEN &apos;STANDARD&apos;&#13;&#10;WHEN NULL THEN &apos;EXCLUDE&apos;&#13;&#10;WHEN &apos;PR&apos; THEN &apos;EXCLUDE&apos;&#13;&#10;WHEN &apos;-&apos; THEN &apos;EXCLUDE&apos;&#13;&#10;END' />
      </column>
      <column caption='BSAT_FLAG' datatype='string' name='[Calculation_733242342003982340]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Calculation_733242341999923202]&#13;&#10;WHEN &apos;GROWTH&apos; THEN &apos;GROWTH&apos;&#13;&#10;WHEN &apos;STANDARD&apos; THEN &apos;STANDARD&apos;&#13;&#10;WHEN &apos;MANAGED&apos; THEN &apos;MANAGED&apos;&#13;&#10;WHEN &apos;NO J2&apos; THEN &apos;STANDARD&apos;&#13;&#10;WHEN NULL THEN &apos;EXCLUDE&apos;&#13;&#10;WHEN &apos;PR&apos; THEN &apos;EXCLUDE&apos;&#13;&#10;WHEN &apos;-&apos; THEN &apos;EXCLUDE&apos;&#13;&#10;END' />
      </column>
      <column caption='KPI_2' datatype='real' name='[Calculation_758856546811756544]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[KPI List (copy)]&#13;&#10;WHEN &quot;MQ&quot; THEN SUM([MailQTY])&#13;&#10;WHEN &quot;DO&quot; THEN SUM([DealerOrders])&#13;&#10;WHEN &quot;DA&quot; THEN SUM([DealerActivations])&#13;&#10;WHEN &quot;OR&quot; THEN sum([DealerOrders])/sum([MailQTY])&#13;&#10;WHEN &quot;AR&quot; THEN sum([DealerActivations])/sum([DealerOrders])&#13;&#10;WHEN &quot;CPDO&quot; THEN 0.45 *( SUM([MailQTY])/SUM([DealerOrders]) )&#13;&#10;END' />
      </column>
      <column caption='Monthly / Weekly View' datatype='string' name='[Calculation_758856546812760065]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Cost Per Call Parameter]&#13;&#10;&#13;&#10;WHEN &apos;QQ&apos; THEN &quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;,[EST_IHD],&apos;Monday&apos;))&#13;&#10;&#13;&#10;WHEN &apos;WW&apos; THEN &quot;Week &quot;+ str(DATEPART(&apos;week&apos;,[EST_IHD],&apos;Monday&apos;)) &#13;&#10;&#13;&#10;WHEN &apos;MM&apos; THEN LEFT(DATENAME(&quot;month&quot;,[EST_IHD]),3)&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Color Code' datatype='string' name='[Calculation_758856546813870082]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='str(year([EST_IHD])) + &quot;-&quot; + [Mail Categ]' />
      </column>
      <column caption='KPI 2' datatype='string' name='[Calculation_758856546817720324]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[KPI List (copy)]' />
      </column>
      <column caption='[KPI_2]/1000' datatype='real' hidden='true' name='[Calculation_758856546820091909]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_758856546811756544]/1000' />
      </column>
      <column caption='Button' datatype='string' name='[Calculation_784752293704478720]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Button&quot;' />
      </column>
      <column caption='KPI_3' datatype='real' name='[Calculation_861031963391651840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[KPI List 2 (copy)]&#13;&#10;WHEN &quot;CPDO&quot; THEN 0.45 *( SUM([MailQTY])/SUM([DealerOrders]) )&#13;&#10;WHEN &quot;CPDA&quot; THEN 0.45 *( sum([MailQTY])/SUM ([DealerActivations]) )&#13;&#10;WHEN &quot;HCPDO&quot; THEN sum([Calculation_354939952077893641]) / SUM([DealerOrders])&#13;&#10;WHEN &quot;DCPDO&quot; THEN sum([Calculation_354939952077586439])/sum([DealerOrders])&#13;&#10;WHEN &quot;SAC&quot; THEN (0.45 *( SUM([MailQTY])/SUM([DealerOrders]) ) ) + 210 + 181&#13;&#10;END' />
      </column>
      <column caption='KPI 3' datatype='string' name='[Calculation_861031963393986561]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[KPI List 2 (copy)]' />
      </column>
      <column datatype='string' hidden='true' name='[Campaign]' role='dimension' type='nominal' />
      <column datatype='string' hidden='true' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='string' hidden='true' name='[Current TM]' role='dimension' type='nominal' />
      <column caption='AR_LKP' datatype='integer' name='[DA_LKP (copy 2)]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF &#13;&#10; (ZN([Calculation_354939952076820484]) - LOOKUP(ZN([Calculation_354939952076820484]), 1)) / ABS(LOOKUP(ZN([Calculation_354939952076820484]), 1)) &lt;0 then -1 &#13;&#10;ELSEIF (ZN([Calculation_354939952076820484]) - LOOKUP(ZN([Calculation_354939952076820484]), 1)) / ABS(LOOKUP(ZN([Calculation_354939952076820484]), 1))= 0 then 0 &#13;&#10;ELSE 1 END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='CPDO_LKP' datatype='integer' name='[DA_LKP (copy)]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF &#13;&#10; (ZN([Calculation_354939952077467654]) - LOOKUP(ZN([Calculation_354939952077467654]), 1)) / ABS(LOOKUP(ZN([Calculation_354939952077467654]), 1)) &lt;0 then -1 &#13;&#10;ELSEIF (ZN([Calculation_354939952077467654]) - LOOKUP(ZN([Calculation_354939952077467654]), 1)) / ABS(LOOKUP(ZN([Calculation_354939952077467654]), 1)) = 0 then 0 &#13;&#10;ELSE 1 END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>

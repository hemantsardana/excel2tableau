              <formatted-text>
                <run fontcolor='#787878'>Mon_yr:&#9;</run>
                <run bold='true'>&lt;[federated.1oam6ps0ouz5g21g569k905nta2o].[none:Calculation_365636011108364294:nk]&gt;</run>

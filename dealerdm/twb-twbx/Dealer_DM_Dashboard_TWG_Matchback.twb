              <calculation class='tableau' formula='IF MONTH([Est_IHD])= MONTH({ EXCLUDE YEAR([Est_IHD]),MONTH([Est_IHD]), [Est_IHD],[Calculation_712413180615208960] :MAX([Est_IHD])} )&#13;&#10;and YEAR([Est_IHD])= YEAR({ EXCLUDE YEAR([Est_IHD]),MONTH([Est_IHD]), [Est_IHD],[Calculation_712413180615208960] :MAX([Est_IHD])} )&#13;&#10;then&#13;&#10;&quot;Current Month&quot;&#13;&#10;ELSEIF &#13;&#10;MONTH([Est_IHD])= MONTH({ EXCLUDE YEAR([Est_IHD]),MONTH([Est_IHD]), [Est_IHD],[Calculation_712413180615208960] :MAX([Est_IHD])} )&#13;&#10;and YEAR([Est_IHD])= YEAR({ EXCLUDE YEAR([Est_IHD]),MONTH([Est_IHD]), [Est_IHD],[Calculation_712413180615208960] :MAX([Est_IHD])} )-1 then&#13;&#10;&quot;Previous Yr&quot;&#13;&#10;END' />

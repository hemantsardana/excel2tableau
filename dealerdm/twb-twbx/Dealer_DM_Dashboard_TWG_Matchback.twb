            <column caption='Home' datatype='string' name='[Calculation_239253744631144449]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Home&quot;' />
            </column>
            <column caption='Year' datatype='integer' name='[Calculation_354939952060190720]' role='dimension' type='ordinal'>

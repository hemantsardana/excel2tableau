            <column caption='Month_1' datatype='string' name='[Calculation_458804226252173315]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT(DATENAME(&quot;month&quot;,[Est_IHD]),3)' />
            </column>
            <column caption='Color Code' datatype='string' name='[Calculation_582090258992340998]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='str(year([Est_IHD])) + &quot;-&quot; + [Mail Type (copy)]' />

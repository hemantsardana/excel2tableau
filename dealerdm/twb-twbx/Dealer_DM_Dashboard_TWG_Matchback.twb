              <calculation class='tableau' formula='IF &#13;&#10;(ZN(SUM([Count])) - LOOKUP(ZN(SUM([Count])), 1)) / ABS(LOOKUP(ZN(SUM([Count])), 1)) &lt;0 then -1 &#13;&#10;ELSEIF (ZN(SUM([Count])) - LOOKUP(ZN(SUM([Count])), 1)) / ABS(LOOKUP(ZN(SUM([Count])), 1))= 0 then 0 &#13;&#10;ELSE 1 END'>

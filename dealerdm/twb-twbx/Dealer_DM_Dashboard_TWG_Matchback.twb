    <worksheet name='#D_MBACK_DCPDO_MT'>
      <table>
        <view>
          <datasources>
            <datasource caption='Matchback Data' name='federated.1oam6ps0ouz5g21g569k905nta2o' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Weekly' caption='Monthly / Weekly View ' datatype='string' name='[Cost Per Call Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;WW&quot;'>
              <calculation class='tableau' formula='&quot;WW&quot;' />
              <aliases>
                <alias key='&quot;MM&quot;' value='Monthly' />
                <alias key='&quot;QQ&quot;' value='Quarterly' />
                <alias key='&quot;WW&quot;' value='Weekly' />
              </aliases>
            </column>
            <column alias='Cost Per Dealer Activation' caption='KPI List 3' datatype='string' name='[KPI List 2 (copy)]' param-domain-type='list' role='measure' type='nominal' value='&quot;CPDA&quot;'>
              <calculation class='tableau' formula='&quot;CPDA&quot;' />
              <aliases>
                <alias key='&quot;CPDA&quot;' value='Cost Per Dealer Activation' />
                <alias key='&quot;CPDO&quot;' value='Cost Per Dealer Order' />
                <alias key='&quot;DCPDO&quot;' value='Dealer Cost Per Dealer Order' />
                <alias key='&quot;HCPDO&quot;' value='Hughes Cost Per Dealer Order' />
                <alias key='&quot;SAC&quot;' value='SAC' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1oam6ps0ouz5g21g569k905nta2o'>
            <column caption='Beam_Status_Today' datatype='string' name='[Beam_Status_At_Time (copy)]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Beam_Status_P9]' />
            </column>
            <column datatype='string' name='[Beam_Status_At_Time (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[Calculation_733242341999923202]' new-bin='true'>
                <bin default-name='false' value='&quot;STANDARD&quot;'>
                  <value>%null%</value>
                  <value>&quot;STANDARD&quot;</value>
                </bin>
              </calculation>
            </column>
            <column caption='Beam Status P1' datatype='string' name='[Beam_Status_P1]' role='dimension' type='nominal' />
            <column caption='Beam Status P2' datatype='string' name='[Beam_Status_P2]' role='dimension' type='nominal' />
            <column caption='Beam Status P3' datatype='string' name='[Beam_Status_P3]' role='dimension' type='nominal' />
            <column caption='Beam Status P4' datatype='string' name='[Beam_Status_P4]' role='dimension' type='nominal' />
            <column caption='Beam Status P5' datatype='string' name='[Beam_Status_P5]' role='dimension' type='nominal' />
            <column caption='Beam Status P6' datatype='string' name='[Beam_Status_P6]' role='dimension' type='nominal' />
            <column caption='Beam Status P7' datatype='string' name='[Beam_Status_P7]' role='dimension' type='nominal' />
            <column caption='Beam Status P8' datatype='string' name='[Beam_Status_P8]' role='dimension' type='nominal' />
            <column datatype='string' name='[Beam_Status_P9]' role='dimension' type='nominal' />
            <column caption='Beam Status Pre P1' datatype='string' name='[Beam_Status_Pre_P1]' role='dimension' type='nominal' />
            <column caption='Beam_Status_Today_Final' datatype='string' name='[Beam_Status_Today (group) 1]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[Beam_Status_At_Time (copy)]' new-bin='true'>
                <bin default-name='false' value='&quot;STANDARD&quot;'>
                  <value>&quot;PR&quot;</value>
                  <value>&quot;STANDARD&quot;</value>
                </bin>
              </calculation>
            </column>
            <column caption='Matchback Navigation 2' datatype='string' name='[Calculation_239253744653062148]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Matchback Dashboard 2&quot;' />
            </column>
            <column aggregation='Sum' caption='Year' datatype='integer' name='[Calculation_354939952070057987]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='YEAR([EST_IHD])' />
            </column>
            <column caption='Cost per Dealer Activation' datatype='real' name='[Calculation_354939952077275141]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='0.45*(sum([MailQTY])/SUM([DealerActivations]))' />
            </column>
            <column caption='Cost per Dealer Order' datatype='real' name='[Calculation_354939952077467654]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='0.45*sum([MailQTY])/SUM([DealerOrders])' />
            </column>
            <column caption='Dealer Cost' datatype='real' name='[Calculation_354939952077586439]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if [Mail Categ] = &quot;Radius&quot; then&#13;&#10;0&#13;&#10;else [MailQTY]*0.45*0.2&#13;&#10;end' />
            </column>
            <column caption='Dealer Cost per Dealer Order' datatype='real' name='[Calculation_354939952077717512]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sum([Calculation_354939952077586439])/sum([DealerOrders])' />
            </column>
            <column caption='Hughes Cost' datatype='real' name='[Calculation_354939952077893641]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if [Mail Categ] = &quot;Radius&quot; then&#13;&#10;[MailQTY]*0.45&#13;&#10;else [MailQTY]*0.45*0.8&#13;&#10;END' />
            </column>
            <column caption='Hughes Cost per Dealer Order' datatype='real' name='[Calculation_354939952078045194]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sum([Calculation_354939952077893641])/SUM([DealerOrders])' />
            </column>
            <column caption='SAC' datatype='real' name='[Calculation_354939952078249996]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_354939952077467654]+210+181' />
            </column>
            <column caption='Beam_Status_At_Time' datatype='string' name='[Calculation_733242341999923202]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='//yyyy - mm - dd&#13;&#10;IF [EST_IHD] &lt; #2018-01-04# THEN [Beam_Status_Pre_P1] //Pre P1&#13;&#10;&#13;&#10;ELSEIF #2018-01-04# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2018-04-05# THEN [Beam_Status_P1] // P1 04Jan18 - 05Apr18&#13;&#10;&#13;&#10;ELSEIF #2018-04-05# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2018-05-31# THEN [Beam_Status_P2] // P2 05Jan18 - 31May18&#13;&#10;&#13;&#10;ELSEIF #2018-05-31# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2018-08-02# THEN [Beam_Status_P3] // P3 31May18 - 02Aug18&#13;&#10;&#13;&#10;ELSEIF #2018-08-02# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2018-09-27# THEN [Beam_Status_P4] // P4 02Aug18 - 27Sep18&#13;&#10;&#13;&#10;ELSEIF #2018-09-27# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2019-01-03# THEN [Beam_Status_P5] // P5 27Sep18 - 03Jan19&#13;&#10;&#13;&#10;ELSEIF #2019-01-03# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2019-01-14# THEN [Beam_Status_P6] // P6 03Jan19 - 14Feb19&#13;&#10;&#13;&#10;ELSEIF #2019-02-14# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2019-03-28# THEN [Beam_Status_P7] // P7 14Feb19 - 28Mar19&#13;&#10;&#13;&#10;ELSEIF #2019-03-28# &lt;= [EST_IHD] and  [EST_IHD] &lt; #2019-06-27# THEN [Beam_Status_P8] // P7 28Mar19 - 27Jun19&#13;&#10;&#13;&#10;ELSEIF #2019-06-27# &lt;= [EST_IHD] THEN [Beam_Status_P9] // P9 27Jun19 - Today&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;//if ORDER_RECEIVED_DATE &lt; &quot;04Jan18&quot;d then period=0;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;04Jan18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;05Apr18&quot;d then period=1;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;05Apr18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;31May18&quot;d then period=2;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;31May18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;02Aug18&quot;d then period=3;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;02Aug18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;27Sep18&quot;d then period=4;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;27Sep18&quot;d and ORDER_RECEIVED_DATE &lt; &quot;03Jan19&quot;d then period=5;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;03Jan19&quot;d and ORDER_RECEIVED_DATE &lt; &quot;14Feb19&quot;d then period=6;else;&#13;&#10;//if ORDER_RECEIVED_DATE &gt;= &quot;14Feb19&quot;d then period=7;else;' />
            </column>
            <column caption='Color Code' datatype='string' name='[Calculation_758856546813870082]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='str(year([EST_IHD])) + &quot;-&quot; + [Mail Categ]' />
            </column>
            <column caption='KPI_3' datatype='real' name='[Calculation_861031963391651840]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[KPI List 2 (copy)]&#13;&#10;WHEN &quot;CPDO&quot; THEN 0.45 *( SUM([MailQTY])/SUM([DealerOrders]) )&#13;&#10;WHEN &quot;CPDA&quot; THEN 0.45 *( sum([MailQTY])/SUM ([DealerActivations]) )&#13;&#10;WHEN &quot;HCPDO&quot; THEN sum([Calculation_354939952077893641]) / SUM([DealerOrders])&#13;&#10;WHEN &quot;DCPDO&quot; THEN sum([Calculation_354939952077586439])/sum([DealerOrders])&#13;&#10;WHEN &quot;SAC&quot; THEN (0.45 *( SUM([MailQTY])/SUM([DealerOrders]) ) ) + 210 + 181&#13;&#10;END' />
            </column>
            <column caption='KPI 3' datatype='string' name='[Calculation_861031963393986561]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[KPI List 2 (copy)]' />
            </column>
            <column datatype='string' name='[Dealer Name (matched)]' role='dimension' type='nominal' />
            <column aggregation='CountD' caption='Dealer Activations' datatype='integer' name='[DealerActivations]' role='measure' type='quantitative' />
            <column aggregation='CountD' caption='Dealer Orders' datatype='integer' name='[DealerOrders]' role='measure' type='quantitative' />
            <column caption='Est Ihd' datatype='date' name='[EST_IHD]' role='dimension' type='ordinal' />
            <column caption='Mail Type' datatype='string' name='[Mail Categ]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[SRC]' new-bin='true'>
                <bin default-name='false' value='&quot;Branded-Saturation&quot;'>
                  <value>&quot;Branded&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Generic-Saturation&quot;'>
                  <value>&quot;Generic&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Radius&quot;'>
                  <value>&quot;Branded Radius&quot;</value>
                  <value>&quot;DealerRadius&quot;</value>
                </bin>
              </calculation>
            </column>
            <column caption='Mail QTY' datatype='integer' name='[MailQTY]' role='measure' type='quantitative' />
            <column caption='Monthly / Weekly View /BDN' datatype='string' name='[Monthly / Weekly View (copy)]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Cost Per Call Parameter]&#13;&#10;&#13;&#10;WHEN &apos;QQ&apos; THEN &quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;,[EST_IHD],&apos;Monday&apos;)) + &quot;&apos;&quot; + RIGHT(STR(DATEPART(&apos;year&apos;,[EST_IHD],&apos;Monday&apos;)),2) &#13;&#10;&#13;&#10;WHEN &apos;WW&apos; THEN &quot;Wk &quot;+ str(DATEPART(&apos;week&apos;,[EST_IHD],&apos;Monday&apos;)) + &quot;&apos;&quot; + RIGHT(STR(DATEPART(&apos;year&apos;,[EST_IHD],&apos;Monday&apos;)),2)&#13;&#10;&#13;&#10;WHEN &apos;MM&apos; THEN  LEFT(DATENAME(&quot;month&quot;,[EST_IHD]),3) + &quot;&apos;&quot; + RIGHT(STR(DATEPART(&apos;year&apos;,[EST_IHD],&apos;Monday&apos;)),2)&#13;&#10;END' />
            </column>
            <column datatype='string' name='[SRC]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_758856546813870082]' derivation='Attribute' name='[attr:Calculation_758856546813870082:nk]' pivot='key' type='nominal' />

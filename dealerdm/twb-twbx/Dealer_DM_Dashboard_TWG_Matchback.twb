            <groupfilter from='&quot;GROWTH&quot;' function='range' level='[none:Beam_Status_At_Time (copy):nk]' to='&quot;STANDARD&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>

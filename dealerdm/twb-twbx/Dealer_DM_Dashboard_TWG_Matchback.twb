      <column caption='OR_LKP' datatype='integer' name='[CPDO_LKP (copy)]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF &#13;&#10;(ZN([Calculation_354939952078143499]) - LOOKUP(ZN([Calculation_354939952078143499]), 1)) / ABS(LOOKUP(ZN([Calculation_354939952078143499]), 1)) &lt;0 then -1 &#13;&#10;ELSEIF (ZN([Calculation_354939952078143499]) - LOOKUP(ZN([Calculation_354939952078143499]), 1)) / ABS(LOOKUP(ZN([Calculation_354939952078143499]), 1)) = 0 then 0 &#13;&#10;ELSE 1 END'>

            <column-instance column='[Monthly / Weekly View (copy)]' derivation='None' name='[none:Monthly / Weekly View (copy):nk]' pivot='key' type='nominal' />
            <column-instance column='[DealerActivations]' derivation='Sum' name='[sum:DealerActivations:qk]' pivot='key' type='quantitative' />
            <column-instance column='[DealerOrders]' derivation='Sum' name='[sum:DealerOrders:qk]' pivot='key' type='quantitative' />
            <column-instance column='[MailQTY]' derivation='Sum' name='[sum:MailQTY:qk]' pivot='key' type='quantitative' />

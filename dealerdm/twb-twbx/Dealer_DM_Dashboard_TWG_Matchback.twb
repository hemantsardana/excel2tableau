            <groupfilter from='&quot;GROWTH&quot;' function='range' level='[none:Calculation_733242341999923202:nk]' to='&quot;STANDARD&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />

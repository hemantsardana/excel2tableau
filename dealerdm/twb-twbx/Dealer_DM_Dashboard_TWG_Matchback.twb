    <worksheet name='TWG Raw Data Sheet'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1'>TWG Raw Data</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='TWG Job Details 2017+ (Multiple Connections)' name='federated.1thqvk50957jk81cxe9td0j0267o' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Weekly' caption='Monthly / Weekly View ' datatype='string' name='[Cost Per Call Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;WW&quot;'>
              <calculation class='tableau' formula='&quot;WW&quot;' />
              <aliases>
                <alias key='&quot;MM&quot;' value='Monthly' />
                <alias key='&quot;QQ&quot;' value='Quarterly' />
                <alias key='&quot;WW&quot;' value='Weekly' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1thqvk50957jk81cxe9td0j0267o'>
            <column caption='Mail Type' datatype='string' name='[Ad_Group1]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;BULK&quot;' value='Branded-Saturation' />
                <alias key='&quot;GENERIC&quot;' value='Generic-Saturation' />
                <alias key='&quot;RADIUS&quot;' value='Radius' />
              </aliases>
            </column>
            <column caption='Year' datatype='integer' name='[Calculation_354939952060190720]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='Year([Est_IHD])' />
            </column>
            <column caption='Cost per Call' datatype='real' name='[Calculation_354939952060768257]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Retailer_Cost])/SUM([Total_Calls])' />
            </column>
            <column caption='Resp. Rate' datatype='real' name='[Calculation_354939952061177858]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Total_Calls])/SUM([Count])' />
            </column>
            <column datatype='integer' name='[Count]' role='measure' type='quantitative' />
            <column caption='Dealer Name' datatype='string' name='[Dealer Name(match)]' role='dimension' type='nominal' />
            <column caption='Est IHD' datatype='date' name='[Est_IHD]' role='dimension' type='ordinal' />
            <column caption='Monthly / Weekly View' datatype='string' name='[Monthly / Weekly View (copy)]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Cost Per Call Parameter]&#13;&#10;&#13;&#10;WHEN &apos;QQ&apos; THEN &quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;,[Est_IHD],&apos;Monday&apos;))&#13;&#10;&#13;&#10;WHEN &apos;WW&apos; THEN &quot;Week &quot;+ str(DATEPART(&apos;week&apos;,[Est_IHD],&apos;Monday&apos;)) &#13;&#10;&#13;&#10;WHEN &apos;MM&apos; THEN LEFT(DATENAME(&quot;month&quot;,[Est_IHD]),3)&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Retailer Cost' datatype='real' name='[Retailer_Cost]' role='measure' type='quantitative' />
            <column caption='Total Calls' datatype='integer' name='[Total_Calls]' role='measure' type='quantitative' />
            <column-instance column='[Ad_Group1]' derivation='None' name='[none:Ad_Group1:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_354939952060190720]' derivation='None' name='[none:Calculation_354939952060190720:ok]' pivot='key' type='ordinal' />
